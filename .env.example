# WhatsApp number for checkout and contact links.
# Format: country code + number, no + or spaces.
# Example Colombia: 573001112233
# Example Argentina: 5493515551234
NEXT_PUBLIC_WHATSAPP_NUMBER=573001112233

# Optional: Base URL for OpenGraph and canonical links (e.g. https://ladelgorila.com)
# NEXT_PUBLIC_SITE_URL=https://ladelgorila.com

# Optional: Fallback contact when WhatsApp is not configured
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/your_account

# Optional: Sanity CMS (for /studio and Sanity-backed content). Not required for runtime.
# NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# SANITY_API_TOKEN=your_token
